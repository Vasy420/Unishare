# UniShare Backend Environment Configuration
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to version control.

# Database
MONGO_URL="mongodb://127.0.0.1:27017"
DB_NAME="unishare"

# JWT Security (generate a strong random key, e.g.: openssl rand -hex 32)
SECRET_KEY="change-me-to-a-64-char-random-string"

# CORS (comma-separated origins, or "*" for dev only)
CORS_ORIGINS="*"

# Admin account (optional — if omitted a random password will be generated on first boot)
ADMIN_EMAIL="admin@unishare.app"
ADMIN_PASSWORD=""

# Frontend / Backend URLs
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://127.0.0.1:8001"

# Google Drive OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_DRIVE_REDIRECT_URI="http://127.0.0.1:8001/api/drive/callback"
